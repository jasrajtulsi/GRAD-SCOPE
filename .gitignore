# Obsidian local / per-machine state (do not sync)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json.bak

# Obsidian trash
.trash/

# OS cruft
.DS_Store

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Datasets (downloaded by torchvision)
data/

# GRAD-SCOPE generated artifacts (keep the dirs, ignore their contents)
results/*
figures/*
!results/.gitkeep
!figures/.gitkeep
